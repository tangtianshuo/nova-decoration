{
	"name": "nova-decoration",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"dev:api": "wrangler dev",
		"dev:all": "concurrently \"pnpm dev\" \"pnpm dev:api\"",
		"e2e": "playwright test",
		"e2e:headed": "playwright test --headed",
		"e2e:ui": "playwright test --ui",
		"e2e:install": "playwright install --with-deps chromium",
		"db:init": "wrangler d1 execute nova-dev --local --file=migrations/0001_init.sql && wrangler d1 execute nova-dev --local --file=migrations/0002_commercial_core.sql",
		"db:clear": "wrangler d1 execute nova-dev --local --command \"DELETE FROM release_audits; DELETE FROM usage_monthly_snapshots; DELETE FROM tenant_quota_overrides; DELETE FROM billing_transactions; DELETE FROM tenant_subscriptions; DELETE FROM plans; DELETE FROM events; DELETE FROM share_links; DELETE FROM page_blocks; DELETE FROM pages; DELETE FROM assets; DELETE FROM users; DELETE FROM companies; DELETE FROM tenants;\"",
		"db:seed": "wrangler d1 execute nova-dev --local --file=migrations/seed.sql",
		"db:reset": "pnpm run db:init && pnpm run db:seed",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"check": "tsc -b --noEmit",
		"test": "vitest run tests"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"lucide-react": "^0.511.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-router-dom": "^7.3.0",
		"tailwind-merge": "^3.0.2",
		"zustand": "^5.0.3",
		"qrcode": "^1.5.4",
		"sonner": "^2.0.3",
		"hono": "^4.7.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.25.0",
		"@types/node": "^22.15.30",
		"@cloudflare/workers-types": "^4.20250422.0",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@types/qrcode": "^1.5.5",
		"wrangler": "^4.14.0",
		"concurrently": "^9.1.0",
		"@vitejs/plugin-react": "^4.4.1",
		"autoprefixer": "^10.4.21",
		"babel-plugin-react-dev-locator": "^1.0.0",
		"postcss": "^8.5.3",
		"tailwindcss": "^3.4.17",
		"eslint": "^9.25.0",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.19",
		"globals": "^16.0.0",
		"@playwright/test": "^1.54.1",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.30.1",
		"vitest": "^2.1.8",
		"vite": "^6.3.5",
		"vite-plugin-trae-solo-badge": "^1.0.0",
		"vite-tsconfig-paths": "^5.1.4"
	}
}
